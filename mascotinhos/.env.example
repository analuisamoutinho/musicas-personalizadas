# =============================================================================
# Mascotinhos — Environment Variables
# =============================================================================
# Copy this file to .env.local (or apps/web/.env) and fill in real values.
# All variables are REQUIRED unless marked (Optional).
# =============================================================================

# --- Supabase (Database + Storage) ---
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- AI APIs ---
GOOGLE_GENERATIVE_AI_API_KEY=AIza...your-gemini-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# --- Asaas (PIX payments) ---
ASAAS_API_KEY=your_asaas_api_key
ASAAS_WEBHOOK_SECRET=your_asaas_webhook_secret
# (Optional) Partner wallet ID for payment split
ASAAS_SPLIT_WALLET_ID=

# --- WhatsApp Business API (Chat SDK) ---
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verification_token
WHATSAPP_APP_SECRET=your_whatsapp_app_secret  # from Meta App Dashboard → App Settings → Basic
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# --- Upstash Redis (conversation history) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token

# --- Upstash QStash (async job queue) ---
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=sig_current_key
QSTASH_NEXT_SIGNING_KEY=sig_next_key

# --- Cron endpoint protection ---
CRON_SECRET=a_random_secret_for_cron_auth

# --- Vercel ---
VERCEL_URL=https://your-app.vercel.app

# --- Operator ---
OPERATOR_WHATSAPP_NUMBER=5511999999999

# --- Langfuse (AI observability — optional) ---
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=https://langfuse.yourdomain.com

# --- Sentry (error monitoring + source maps) ---
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, project:read
# Add to Vercel: cd mascotinhos && echo "<token>" | vercel env add SENTRY_AUTH_TOKEN production
SENTRY_AUTH_TOKEN=sntrys_your_auth_token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# --- Node ---
NODE_ENV=development

# --- Client-side (NEXT_PUBLIC_ prefix — exposed to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
# Sentry DSN (public, safe to expose — find in Sentry project settings → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXXXX
