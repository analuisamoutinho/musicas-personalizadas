# =============================================================================
# Mascotinhos — Environment Variables
#
# Copy this file to .env (local dev) and fill in real values.
# For Vercel, set each var in the dashboard under Project → Settings → Environment
# Variables. See docs/preview-environment.md for the full Preview setup guide.
#
# Scope legend (Vercel):
#   [prod]    Production only
#   [all]     Production + Preview + Development
#   [preview] Preview only (separate value from Production)
#   [auto]    Auto-injected by Vercel — do NOT set manually
# =============================================================================

# -- Database (Supabase / PostgreSQL) ----------------------------------------
# [all] Prisma connection pool URL (PgBouncer)
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true"

# [all] Direct connection for migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# [all] Supabase project URL
SUPABASE_URL="https://[ref].supabase.co"

# [all] Supabase service-role key (server-side only — never expose to clients)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -- Client-side Supabase -----------------------------------------------------
# [all] Public Supabase project URL (mirrored from SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"

# -- AI / LLM -----------------------------------------------------------------
# [all] OpenAI API key
OPENAI_API_KEY="sk-..."

# [all] (optional) Google Generative AI key for Gemini
GOOGLE_GENERATIVE_AI_API_KEY=""

# -- Billing (Asaas) ----------------------------------------------------------
# [all] Asaas API key (use sandbox key for Preview if available)
ASAAS_API_KEY="$aact_..."

# [all] Asaas webhook HMAC secret
ASAAS_WEBHOOK_SECRET="..."

# [all] (optional) Asaas split-payment wallet ID
ASAAS_SPLIT_WALLET_ID=""

# -- WhatsApp (Meta Cloud API) ------------------------------------------------
# [preview] Phone number ID for the PREVIEW WhatsApp number
# [prod]    Phone number ID for the PRODUCTION WhatsApp number
WHATSAPP_PHONE_NUMBER_ID="1234567890"

# [preview] Access token scoped to the PREVIEW WhatsApp number
# [prod]    Access token scoped to the PRODUCTION WhatsApp number
WHATSAPP_ACCESS_TOKEN="EAAx..."

# [all] Meta app secret (same app can serve both numbers)
WHATSAPP_APP_SECRET="..."

# [preview] Webhook verify token for the PREVIEW webhook endpoint
# [prod]    Webhook verify token for the PRODUCTION webhook endpoint
WHATSAPP_WEBHOOK_TOKEN="my-secure-random-token"

# [preview] E.164 WhatsApp number shown in landing-page CTAs for Preview
# [prod]    Production WhatsApp number
NEXT_PUBLIC_WHATSAPP_NUMBER="5511999999999"

# [all] Operator's personal WhatsApp number (digits only, no +)
OPERATOR_WHATSAPP_NUMBER="5511999999999"

# -- Queue / Upstash ----------------------------------------------------------
# [all] Upstash Redis REST URL
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"

# [all] Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN="AX..."

# [all] QStash token
QSTASH_TOKEN="eyJ..."

# [all] QStash signing keys (rotate monthly; current + next for zero-downtime rotation)
QSTASH_CURRENT_SIGNING_KEY="sig_..."
QSTASH_NEXT_SIGNING_KEY="sig_..."

# -- Security -----------------------------------------------------------------
# [all] Secret for /api/cron/* endpoints
CRON_SECRET="..."

# -- Observability ------------------------------------------------------------
# [all] (optional) Sentry DSN — set in Preview scope too so errors are captured
NEXT_PUBLIC_SENTRY_DSN="https://[key]@o[id].ingest.sentry.io/[project]"

# [all] Sentry org/project slugs (used by withSentryConfig in next.config.ts)
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="mascotinhos"

# [all] (optional) Sentry auth token for source-map upload
SENTRY_AUTH_TOKEN="sntrys_..."

# [all] (optional) Umami analytics website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# [all] (optional) Langfuse public key for AI cost tracking
LANGFUSE_PUBLIC_KEY=""

# [all] (optional) Langfuse secret key
LANGFUSE_SECRET_KEY=""

# [all] (optional) Langfuse base URL (default: cloud.langfuse.com)
LANGFUSE_BASE_URL=""

# -- Vercel system vars (auto-injected — do NOT set manually) -----------------
# VERCEL_URL   — unique hostname for this deployment (e.g. mascotinhos-abc123.vercel.app)
# VERCEL_ENV   — "production" | "preview" | "development"
# NEXT_PUBLIC_VERCEL_ENV — same as VERCEL_ENV, accessible in client bundles
