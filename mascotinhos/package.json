{
  "name": "mascotinhos",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@supabase/supabase-js": "^2.43.0",
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.2.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "@upstash/qstash": "^2.7.22",
      "@types/bun": "^1.3.11"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @mascotinhos/db db:push",
    "db:studio": "turbo -F @mascotinhos/db db:studio",
    "db:generate": "turbo -F @mascotinhos/db db:generate",
    "db:migrate": "turbo -F @mascotinhos/db db:migrate",
    "db:seed": "turbo -F @mascotinhos/db db:seed",
    "test": "turbo test",
    "prepare": "husky"
  },
  "dependencies": {
    "@mascotinhos/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mascotinhos/config": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "next": "^16.2.2",
    "promptfoo": "^0.121.3",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": ""
  },
  "packageManager": "bun@1.3.5"
}
