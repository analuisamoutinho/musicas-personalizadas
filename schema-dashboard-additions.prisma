// Tabela para os dados que vêm da conta de anúncios (preenchida manualmente por enquanto)
// Futuramente pode ser populada automaticamente via Meta Ads API
model MetricaDiaria {
  id          String   @id @default(cuid())
  data        DateTime @unique // apenas a data, sem hora
  diaSemana   String?  // "segunda", "terça", etc.
  investido   Float    @default(0)
  leads       Int      @default(0)

  @@index([data])
}

